generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ResStatus {
  PENDING
  ASSIGNED
  COMPLETED
  R_RECEIVED
}

enum EmailDirection {
  INCOMING
  OUTGOING
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String?
  name      String?
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  // Relations
  reservations Reservation[]
  reminders    Reminder[]
}

model Reservation {
  id        String @id @default(cuid())
  userEmail String
  user      User   @relation(fields: [userEmail], references: [email])

  startAt     DateTime
  endAt       DateTime?
  pickupText  String?
  dropoffText String?
  pax         Int       @default(1)
  priceEuro   Float? // <- keep FLOAT to match prod
  notes       String?

  phone  String? @db.VarChar(40)
  flight String? @db.VarChar(40)

  status    ResStatus @default(PENDING)
  isDeleted Boolean   @default(false) // ✅ added field

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reminders Reminder[]
}

model Reminder {
  id        String @id @default(cuid())
  userEmail String
  user      User   @relation(fields: [userEmail], references: [email])

  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id])

  title  String
  note   String?
  dueAt  DateTime
  isDone Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userEmail, dueAt])
}

model EmailThread {
  id            String         @id @default(cuid())
  subject       String?
  customerEmail String?
  customerName  String?
  lastMessageAt DateTime?
  unread        Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  messages      EmailMessage[]

  @@index([lastMessageAt])
  @@index([unread, lastMessageAt])
}

model EmailMessage {
  id           String            @id @default(cuid())
  threadId     String
  messageId    String            @unique
  inReplyTo    String?
  referenceIds String[]          @default([])
  fromEmail    String?
  fromName     String?
  toEmails     String?
  ccEmails     String?
  subject      String?
  bodyHtml     String?
  bodyText     String?
  direction    EmailDirection
  folder       String?
  folders      String[]          @default([])
  mailbox      String?
  mailboxes    String[]          @default([])
  imapUid      Int?
  receivedAt   DateTime?
  sentAt       DateTime?
  createdAt    DateTime          @default(now())
  thread       EmailThread       @relation(fields: [threadId], references: [id], onDelete: Cascade)
  attachments  EmailAttachment[]

  @@index([threadId, receivedAt])
  @@index([threadId, sentAt])
  @@index([inReplyTo])
  @@index([folder, createdAt])
  @@index([folders], type: Gin)
  @@index([mailbox, imapUid])
  @@index([mailboxes], type: Gin)
}

model EmailAttachment {
  id          String       @id @default(cuid())
  messageId   String
  filename    String
  mimeType    String?
  size        Int?
  storagePath String?
  createdAt   DateTime     @default(now())
  message     EmailMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model EmailSyncState {
  id          String   @id @default(cuid())
  mailbox     String   @unique
  uidValidity BigInt
  lastUid     Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
